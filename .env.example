# ─────────────────────────────────────────────────────────────────────────────
# SYNERVOL — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
#
# 1. Copy this file:  cp .env.example .env
# 2. Paste your Cloudflare Tunnel token below
#    (Cloudflare Dashboard → Zero Trust → Networks → Tunnels → your tunnel → Configure → Token)
#
# IMPORTANT: Never commit your .env file to Git.

CLOUDFLARE_TUNNEL_TOKEN=paste_your_token_here
